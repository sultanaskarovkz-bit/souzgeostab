# СоюзГеоСтаб - конфигурация Apache
# Главное здесь - 301-редиректы: старые адреса Tilda проиндексированы,
# и без переадресации на переезде потеряется накопленное.

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- https и канонический хост ----------------------------------------
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # --- Старые ЧПУ Tilda -> новая структура ------------------------------
  RewriteRule ^tehnologii/?$                              /tehnologii/                      [R=301,L]
  RewriteRule ^kontakty/?$                                /kontakty/                        [R=301,L]
  RewriteRule ^o-nas/?$                                   /                                 [R=301,L]

  RewriteRule ^gornodobyvayushchaya-otrasl/?$             /otrasli/shahty-i-karery/                  [R=301,L]
  RewriteRule ^stroitelnaya-otrasl/?$                     /otrasli/zdaniya-i-sooruzheniya/           [R=301,L]
  RewriteRule ^transportnaya-infrastruktura/?$            /otrasli/dorogi-zhd-aerodromy/             [R=301,L]
  RewriteRule ^gidrotekhnicheskaya-infrastruktura/?$      /otrasli/gidrotehnicheskie-sooruzheniya/   [R=301,L]
  RewriteRule ^toplivno-energeticheskaya-infrastruktura/?$ /otrasli/promyshlennye-obekty/            [R=301,L]
  RewriteRule ^inzhenernye-izyskaniya-i-soprovozhdenie/?$ /tehnologii/geofizicheskiy-kontrol/        [R=301,L]

  # --- Технические адреса экспорта Tilda --------------------------------
  RewriteRule ^page151351773\.html$   /                                          [R=301,L]
  RewriteRule ^page124825003\.html$   /                                          [R=301,L]
  RewriteRule ^page124813563\.html$   /                                          [R=301,L]
  RewriteRule ^page125108153\.html$   /                                          [R=301,L]
  RewriteRule ^page125260053\.html$   /                                          [R=301,L]
  RewriteRule ^page125532463\.html$   /tehnologii/                               [R=301,L]
  RewriteRule ^page125597943\.html$   /kontakty/                                 [R=301,L]
  RewriteRule ^page125598063\.html$   /otrasli/dorogi-zhd-aerodromy/             [R=301,L]
  RewriteRule ^page134650393\.html$   /otrasli/shahty-i-karery/                  [R=301,L]
  RewriteRule ^page134652573\.html$   /otrasli/gidrotehnicheskie-sooruzheniya/   [R=301,L]
  RewriteRule ^page134655203\.html$   /otrasli/zdaniya-i-sooruzheniya/           [R=301,L]
  RewriteRule ^page134656523\.html$   /otrasli/promyshlennye-obekty/             [R=301,L]
  RewriteRule ^page134660273\.html$   /tehnologii/geofizicheskiy-kontrol/        [R=301,L]
  RewriteRule ^page153727883\.html$   /                                          [R=301,L]

  # --- Единообразие адресов: со слешем на конце -------------------------
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# Служебная папка сборщика наружу не отдаётся
RedirectMatch 404 ^/tools/

ErrorDocument 404 /index.html

# --- Сжатие --------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Кэширование ---------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType video/mp4               "access plus 1 year"
  ExpiresByType application/pdf         "access plus 1 month"
  # HTML не кэшируем: правки должны доезжать до пользователя сразу
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

AddType image/webp .webp
AddType image/svg+xml .svg
AddType video/mp4 .mp4

AddDefaultCharset UTF-8
